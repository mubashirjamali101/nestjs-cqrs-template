{
  "name": "nestjs-cqrs-template",
  "version": "0.0.1",
  "description": "NestJS CQRS Template",
  "author": "mubashirjamali101@gmail.com",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "build:old": "nest build && pnpm sentry:sourcemaps",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "prisma:resetdb": "npx prisma migrate reset --force",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio",
    "seed": "ts-node prisma/seed.ts",
    "sentry": "npx @sentry/wizard@latest -i sourcemaps --saas",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org zenkoders-ph --project node-nestjs ./dist && sentry-cli sourcemaps upload --org zenkoders-ph --project node-nestjs ./dist"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.1.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/cqrs": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-fastify": "^11.0.10",
    "@nestjs/swagger": "^11.0.6",
    "@opentelemetry/auto-instrumentations-node": "^0.56.1",
    "@opentelemetry/instrumentation-nestjs-core": "^0.44.1",
    "@opentelemetry/sdk-node": "^0.57.2",
    "@paralleldrive/cuid2": "^2.2.2",
    "@prisma/client": "^6.4.1",
    "@sentry/cli": "^2.42.2",
    "@sentry/nestjs": "^9.2.0",
    "@sentry/profiling-node": "^9.2.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "nest-router": "^1.0.9",
    "nest-winston": "^1.10.2",
    "nestjs-otel": "^6.1.2",
    "nodemailer": "^7.0.11",
    "paseto": "^3.1.4",
    "pg": "^8.13.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-themes": "^1.4.3",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.2",
    "prisma": "^6.4.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.3.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@scarf/scarf",
      "@sentry-internal/node-cpu-profiler",
      "@sentry/cli",
      "@swc/core",
      "bcrypt",
      "esbuild",
      "prisma",
      "protobufjs"
    ]
  }
}
